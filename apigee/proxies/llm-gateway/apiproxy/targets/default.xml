<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<TargetEndpoint name="default">
  <Description>Dynamic Vertex AI target</Description>

  <HTTPTargetConnection>
    <!-- Base URL — overridden by target.url set in JS-ModelRouter (TargetEndpoint PreFlow) -->
    <URL>https://aiplatform.googleapis.com</URL>
    <SSLInfo><Enabled>true</Enabled></SSLInfo>
    <Properties>
      <!-- Prevent proxy path suffix (/chat/completions) from being appended to target.url -->
      <Property name="copy.pathsuffix">false</Property>
      <!-- Treat ALL HTTP status codes (incl. 4xx/5xx) as successful so ProxyEndpoint
           response PreFlow runs for backend errors — enables JS-ResponseNormalizer
           to normalize backend error bodies to consistent {"error":{...}} format -->
      <Property name="success.codes">1xx,2xx,3xx,4xx,5xx</Property>
    </Properties>
    <Authentication>
      <GoogleAccessToken>
        <Scopes>
          <Scope>https://www.googleapis.com/auth/cloud-platform</Scope>
        </Scopes>
      </GoogleAccessToken>
    </Authentication>
  </HTTPTargetConnection>

  <PreFlow name="PreFlow">
    <Request>
      <!-- IMPORTANT: target.url must be set HERE (TargetEndpoint), not ProxyEndpoint -->
      <Step><Name>JS-ModelRouter</Name></Step>
      <!-- Normalize OpenAI request body → backend format -->
      <Step><Name>JS-RequestNormalizer</Name></Step>
    </Request>
    <Response/>
  </PreFlow>

  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
</TargetEndpoint>
